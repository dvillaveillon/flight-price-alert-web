# ==========================================================================
# .env.example  —  Plantilla de variables de entorno
# --------------------------------------------------------------------------
# Copia este archivo como `.env` y completa SOLO lo que necesites.
# NUNCA subas tu `.env` real a GitHub (ya esta en .gitignore).
#
# El proyecto funciona SIN NINGUNA de estas variables (modo demo: mock + CSV).
# ==========================================================================

# --- Proveedor de vuelos: mock (default) | amadeus | duffel ---
FLIGHT_PROVIDER=mock

# --- Base de datos Supabase (si se omite, se usa CSV local) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Amadeus Flight Offers Search (si FLIGHT_PROVIDER=amadeus) ---
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# --- Duffel Offers API (si FLIGHT_PROVIDER=duffel) ---
DUFFEL_ACCESS_TOKEN=

# --- SendGrid (email). Si se omite, el email va en modo dry-run ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alertas@tudominio.com

# --- Twilio WhatsApp (si se omite, WhatsApp va en modo dry-run) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Reglas de negocio ---
NOTIFY_COOLDOWN_HOURS=24

# --- (Opcional) proteccion del dashboard admin ---
ADMIN_PASSWORD=

# --- Branding somosrata (opcional: si se omiten, se usan estos mismos defaults) ---
BRAND_LOGO_URL=
BRAND_PRIMARY_COLOR=#16B8B8
BRAND_SECONDARY_COLOR=#0B1F3A
BRAND_ACCENT_COLOR=#FF6B5F
BRAND_YELLOW=#FFC84D
